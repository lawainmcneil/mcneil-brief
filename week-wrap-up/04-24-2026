<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>The Week Wrap Up — April 24, 2026</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Barlow+Condensed:wght@400;600;700&family=Source+Serif+4:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8D59A;
    --gold-dark: #8C6E2A;
    --ink: #1A1612;
    --ink-mid: #3D3028;
    --slate: #4A4540;
    --warm-white: #F8F4ED;
    --cream: #F0EAD8;
    --rule: rgba(201,168,76,0.3);
    --page-bg: #e8e0d0;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { background: var(--page-bg); }
  body {
    font-family: 'Source Serif 4', Georgia, serif;
    color: var(--slate);
    padding: 48px 20px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  .doc {
    max-width: 720px;
    margin: 0 auto;
    background: var(--warm-white);
    box-shadow: 0 4px 40px rgba(0,0,0,0.08);
    overflow: hidden;
  }

  /* ===== Cover band ===== */
  .cover {
    background: linear-gradient(170deg, #1A1612 0%, #2E2318 55%, #1A1612 100%);
    background-color: #1A1612;
    color: var(--warm-white);
    padding: 40px 48px 44px;
    position: relative;
    overflow: hidden;
  }
  .cover-ornament {
    position: absolute;
    right: -80px;
    top: -40px;
    width: 320px;
    height: 320px;
    opacity: 0.12;
    pointer-events: none;
  }
  .cover-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 60px;
    position: relative;
    z-index: 1;
  }
  .logotype {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 18px;
    letter-spacing: 0.15em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
  }
  .cover-title { position: relative; z-index: 1; }
  .rule-bar {
    width: 48px; height: 2px;
    background: var(--gold);
    margin-bottom: 24px;
  }
  .cover-title h1 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 400;
    font-size: 40px;
    line-height: 1.15;
    color: var(--warm-white);
    margin-bottom: 18px;
    letter-spacing: -0.005em;
  }
  .cover-title h1 em {
    color: var(--gold);
    font-style: italic;
  }
  .subtitle {
    font-size: 13px;
    color: rgba(248,244,237,0.7);
    padding-top: 14px;
    border-top: 1px solid rgba(201,168,76,0.35);
    letter-spacing: 0.02em;
  }
  .byline {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(248,244,237,0.75);
    text-transform: uppercase;
    margin-top: 10px;
  }

  /* ===== Opening note ===== */
  .opening {
    padding: 48px 48px 16px;
  }
  .section-eyebrow {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: 14px;
    display: inline-block;
  }
  .opening p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--slate);
  }

  /* ===== Stories section ===== */
  .stories { padding: 40px 48px 32px; }
  .stories-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }
  .stories-header .section-eyebrow { margin-bottom: 0; }
  .stories-header::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--rule);
  }
  .story {
    display: grid;
    grid-template-columns: 88px 1fr;
    gap: 20px;
    padding: 24px 0 28px;
    border-top: 1px solid var(--rule);
  }
  .story:first-of-type { border-top: none; padding-top: 0; }
  .story-num {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 56px;
    line-height: 1;
    color: var(--gold);
    padding-top: 4px;
  }
  .story-body { min-width: 0; }
  .story h2 {
    font-family: 'Playfair Display', Georgia, serif;
    font-weight: 400;
    font-size: 21px;
    line-height: 1.3;
    color: var(--ink);
    margin-bottom: 8px;
    letter-spacing: -0.005em;
  }
  .story h2 a {
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .story h2 a:hover {
    border-color: var(--gold);
    color: var(--gold-dark);
  }
  .story-meta {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--slate);
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .story-meta .divider { color: var(--gold); margin: 0 10px; }
  .story-blurb {
    font-size: 15px;
    line-height: 1.65;
    color: var(--slate);
    margin-bottom: 16px;
  }
  .angle {
    background: var(--cream);
    border-left: 3px solid var(--gold);
    padding: 14px 18px 14px 18px;
  }
  .angle-label {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.25em;
    color: var(--gold-dark);
    text-transform: uppercase;
    display: block;
    margin-bottom: 6px;
  }
  .angle-body {
    font-family: 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-weight: 400;
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink-mid);
  }

  /* ===== Footer ===== */
  .foot {
    padding: 24px 48px 28px;
    text-align: center;
    border-top: 1px solid var(--rule);
  }
  .foot .line-1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 700;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: var(--slate);
    text-transform: uppercase;
    margin-bottom: 6px;
  }
  .foot .line-2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 600;
    font-size: 9.5px;
    letter-spacing: 0.2em;
    color: var(--gold-dark);
    text-transform: uppercase;
  }
  .foot .dot { color: var(--gold); margin: 0 10px; }

  /* ===== Responsive ===== */
  @media (max-width: 600px) {
    body { padding: 16px 0; }
    .doc { max-width: 100%; }
    .cover, .opening, .stories, .foot { padding-left: 24px; padding-right: 24px; }
    .cover-title h1 { font-size: 30px; }
    .story { grid-template-columns: 56px 1fr; gap: 12px; }
    .story-num { font-size: 40px; }
    .story h2 { font-size: 19px; }
  }

  /* ===== Print ===== */
  @media print {
    body { background: white; padding: 0; }
    .doc { box-shadow: none; max-width: 100%; }
    .cover { background: #1A1612 !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
  }
</style>
</head>
<body>
<div class="doc">

  <!-- Cover band -->
  <header class="cover">
    <svg class="cover-ornament" viewBox="0 0 280 280" fill="none" aria-hidden="true">
